# LEVEL — Required Environment Variables
# Copy this to .env and fill in your values.

# Supabase (required)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Sentry (optional — error tracking)
EXPO_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# PostHog (optional — analytics)
EXPO_PUBLIC_POSTHOG_API_KEY=phc_your-posthog-key
EXPO_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# RevenueCat (optional — subscriptions, not used in Milestone A)
EXPO_PUBLIC_REVENUECAT_IOS_KEY=appl_your-key
EXPO_PUBLIC_REVENUECAT_ANDROID_KEY=goog_your-key
